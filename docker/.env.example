# ═══════════════════════════════════════════════════════════
# OpenClaw Docker Environment — Copy to .env and fill in
# ═══════════════════════════════════════════════════════════

# PostgreSQL
POSTGRES_PASSWORD=change-me-to-a-strong-password

# n8n
N8N_ENCRYPTION_KEY=change-me-to-a-random-32-char-string
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_USER=admin
N8N_PASSWORD=change-me-openclaw-admin

# Webhook URL (update for production with your domain)
WEBHOOK_URL=http://localhost:5678/
