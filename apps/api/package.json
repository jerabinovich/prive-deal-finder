{
  "name": "@prive/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "test": "jest --config jest.config.js --runInBand",
    "test:unit": "jest --config jest.config.js --runInBand src",
    "test:e2e": "jest --config jest.config.js --runInBand test/app.e2e.spec.ts",
    "prisma:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
