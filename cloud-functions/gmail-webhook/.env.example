# ═══════════════════════════════════════════════════════════
# OpenClaw Cloud Function — Environment Variables
# Copy to .env and fill in actual values
# ═══════════════════════════════════════════════════════════

# GCP
GCP_PROJECT_ID=prive-openclaw

# n8n Webhook URLs (update after n8n is running)
N8N_WEBHOOK_JR=https://your-n8n-domain.com/webhook/gmail-jr
N8N_WEBHOOK_AMANDA=https://your-n8n-domain.com/webhook/gmail-amanda

# Webhook authentication secret
N8N_WEBHOOK_SECRET=your-random-secret-here
