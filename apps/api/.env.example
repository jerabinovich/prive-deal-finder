# Application
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prive_dev

# JWT
JWT_SECRET=replace_with_at_least_16_char_secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=replace_with_at_least_16_char_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# Auth cookies
AUTH_ADMIN_EMAILS=admin@example.com
AUTH_COOKIE_ACCESS_NAME=prive_access_token
AUTH_COOKIE_REFRESH_NAME=prive_refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
# AUTH_COOKIE_DOMAIN=

# Web app
WEB_APP_URL=http://localhost:3000

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your_google_oauth_client_id
GOOGLE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# Miami-Dade Property Appraiser (MDPA)
MDPA_BULK_FILE_PATH=/path/to/mdpa_bulk_file.csv
MDPA_MAX_ROWS=1000
MDPA_REQUIRE_CONFIRMATION=true
MDPA_ESTIMATED_CREDITS=50

# ArcGIS
ARCGIS_MAX_ROWS=50

# Parcel data sources
MIAMI_DADE_PARCELS_URL=https://opendata.arcgis.com/datasets/your-miami-dade-dataset.geojson
BROWARD_PARCELS_URL=https://opendata.arcgis.com/datasets/your-broward-dataset.geojson
PALM_BEACH_PARCELS_URL=https://opendata.arcgis.com/datasets/your-palm-beach-dataset.geojson

# Geocoding (optional)
GEOCODING_PROVIDER=none
# GEOCODING_API_KEY=your_key_if_using_google

# Agents / OpenAI (optional; needed for chat and scoring)
# OPENAI_API_KEY=sk-...
# AGENTS_V1_ENABLED=true
# AGENTS_RESPONSES_ENABLED=true
# AGENTS_DEFAULT_MODEL=gpt-4.1-mini

# Redis (optional; defaults to 127.0.0.1:6379)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379

# Miami-Dade Foreclosure / Broward Foreclosure (optional)
# MIAMI_DADE_FORECLOSURE_URL=
# MIAMI_DADE_FORECLOSURE_API_KEY=
# BROWARD_FORECLOSURE_URL=
# BROWARD_FORECLOSURE_API_KEY=
