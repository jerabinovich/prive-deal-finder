# API URL (must match PORT in apps/api/.env)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Optional: Google Maps embed on deal detail page
# NEXT_PUBLIC_GOOGLE_MAPS_EMBED_API_KEY=your_maps_embed_key

# Optional: disable chat panel (default enabled)
# NEXT_PUBLIC_CHAT_ENABLE=false

# Optional: API request timeout in ms (default 60000)
# NEXT_PUBLIC_API_TIMEOUT_MS=60000
